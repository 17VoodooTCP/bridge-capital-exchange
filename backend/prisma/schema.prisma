generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  SUPPORT
  ADMIN
  SUPER_ADMIN
}

enum KYCStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BUY
  SELL
  TRANSFER
  STAKE
  UNSTAKE
  REWARD
  FEE
  ADMIN_ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
  STOP_LIMIT
  STOP_MARKET
}

enum OrderStatus {
  OPEN
  FILLED
  PARTIALLY_FILLED
  CANCELLED
  REJECTED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  name             String
  passwordHash     String
  role             UserRole  @default(USER)
  kycStatus        KYCStatus @default(NONE)
  isHeld           Boolean   @default(false)
  holdReason       String?
  antiPhishingCode String?
  twoFactorSecret  String?
  twoFactorEnabled Boolean   @default(false)
  country          String?
  phone            String?
  avatarUrl        String?
  withdrawalLimit  Decimal   @default(100000) @db.Decimal(18, 2)
  refreshTokenHash String?
  resetTokenHash   String?
  resetTokenExpires DateTime?
  emailVerified    Boolean   @default(false)
  emailOtpHash     String?
  emailOtpExpires  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastLoginAt      DateTime?

  wallets       Wallet[]
  transactions  Transaction[]
  orders        Order[]
  positions     StakingPosition[]
  kycDocuments  KYCDocument[]
  tickets       SupportTicket[]
  messages      ChatMessage[]
  sessions      LoginSession[]
  adminLogs     AdminLog[]        @relation("AdminActor")
  notifications Notification[]
  copyPositions CopyPosition[]
  limitRequests LimitIncreaseRequest[]
}

model LimitIncreaseRequest {
  id             String    @id @default(uuid())
  userId         String
  currentLimit   Decimal   @db.Decimal(18, 2)
  requestedLimit Decimal   @db.Decimal(18, 2)
  reason         String?
  status         String    @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewNote     String?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
}

model Wallet {
  id            String  @id @default(uuid())
  userId        String
  asset         String
  balance       Decimal @default(0) @db.Decimal(36, 18)
  lockedBalance Decimal @default(0) @db.Decimal(36, 18)
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, asset])
}

model Transaction {
  id          String            @id @default(uuid())
  userId      String
  type        TransactionType
  asset       String
  amount      Decimal           @db.Decimal(36, 18)
  fee         Decimal           @default(0) @db.Decimal(36, 18)
  status      TransactionStatus @default(PENDING)
  txHash      String?
  fromAddress String?
  toAddress   String?
  network     String?
  note        String?
  usdValue    Decimal           @default(0) @db.Decimal(20, 2)
  createdAt   DateTime          @default(now())
  completedAt DateTime?
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Order {
  id            String      @id @default(uuid())
  userId        String
  symbol        String
  assetName     String?
  side          OrderSide
  type          OrderType
  amount        Decimal     @db.Decimal(36, 18)
  price         Decimal     @default(0) @db.Decimal(36, 18)
  filledAmount  Decimal     @default(0) @db.Decimal(36, 18)
  averagePrice  Decimal     @default(0) @db.Decimal(36, 18)
  fee           Decimal     @default(0) @db.Decimal(36, 18)
  status        OrderStatus @default(OPEN)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model StakingPlan {
  id            String            @id @default(uuid())
  asset         String
  name          String
  apr           Float
  duration      Int               @default(0)
  isFlexible    Boolean           @default(false)
  minAmount     Decimal           @db.Decimal(36, 18)
  maxAmount     Decimal?          @db.Decimal(36, 18)
  isActive      Boolean           @default(true)
  positions     StakingPosition[]
}

model StakingPosition {
  id        String      @id @default(uuid())
  userId    String
  planId    String
  amount    Decimal     @db.Decimal(36, 18)
  earned    Decimal     @default(0) @db.Decimal(36, 18)
  status    String      @default("ACTIVE")
  startDate DateTime    @default(now())
  endDate   DateTime?
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      StakingPlan @relation(fields: [planId], references: [id])

  @@index([userId])
}

model KYCDocument {
  id         String   @id @default(uuid())
  userId     String
  type       String
  fileUrl    String
  status     String   @default("PENDING")
  reviewNote String?
  reviewedBy String?
  reviewedAt DateTime?
  uploadedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SupportTicket {
  id        String        @id @default(uuid())
  userId    String
  subject   String
  status    TicketStatus  @default(OPEN)
  priority  String        @default("MEDIUM")
  category  String?
  assignedTo String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId])
}

model ChatMessage {
  id        String        @id @default(uuid())
  ticketId  String
  senderId  String
  content   String
  fileUrl   String?
  isRead    Boolean       @default(false)
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender    User          @relation(fields: [senderId], references: [id])

  @@index([ticketId])
}

model AdminLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  targetId   String?
  targetType String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  admin      User     @relation("AdminActor", fields: [adminId], references: [id])

  @@index([adminId])
}

model LoginSession {
  id         String   @id @default(uuid())
  userId     String
  ipAddress  String?
  country    String?
  city       String?
  deviceType String?
  carrier    String?
  userAgent  String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WalletConfig {
  id            String  @id @default(uuid())
  asset         String
  network       String
  address       String
  qrCodeUrl     String?
  minDeposit    Decimal @default(0) @db.Decimal(36, 18)
  maxWithdrawal Decimal @default(0) @db.Decimal(36, 18)
  isActive      Boolean @default(true)
  confirmations Int     @default(1)

  @@unique([asset, network])
}

model Trader {
  id            String   @id @default(uuid())
  name          String
  handle        String   @unique
  avatarType    String   @default("INITIALS") // INITIALS | ASSET | PHOTO
  avatarValue   String?  // asset symbol, or an abstract avatar seed
  market        String   @default("CRYPTO")   // CRYPTO | STOCKS | MIXED
  strategy      String
  // Performance figures are SIMULATED/backtested model results, not guarantees
  wins          Int      @default(0)
  losses        Int      @default(0)
  winRate       Float    @default(0)
  roi30d        Float    @default(0)  // simulated 30-day ROI %
  profitSharePct Float   @default(10)
  aum           Float    @default(0)  // assets copying this strategy
  copiers       Int      @default(0)
  riskLevel     String   @default("MEDIUM") // LOW | MEDIUM | HIGH
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  positions CopyPosition[]
}

model CopyPosition {
  id          String   @id @default(uuid())
  userId      String
  traderId    String
  asset       String   @default("USDT") // which wallet asset the allocation came from
  allocation  Float    @default(0) // amount allocated to copy
  status      String   @default("ACTIVE") // ACTIVE | STOPPED
  pnl         Float    @default(0)
  startedAt   DateTime @default(now())
  stoppedAt   DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trader      Trader   @relation(fields: [traderId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String   @default("GENERAL") // GENERAL | TRANSACTION | SECURITY | KYC | ACCOUNT
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model AppSetting {
  key   String @id
  value String
}

model SecureVault {
  id            String   @id @default(uuid())
  asset         String
  network       String
  encryptedData String
  dataType      String
  createdAt     DateTime @default(now())
}
